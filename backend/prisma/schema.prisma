// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum MetricEventType {
  CLICK
  IMPRESSION
  SCREEN_VIEW
  SESSION_START
  SESSION_END
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts              Account[]
  categories            Category[]
  transactions          Transaction[]
  budgets               Budget[]
  creditCards           CreditCard[]
  recurringTransactions RecurringTransaction[]
  experimentAssignments UserExperimentAssignment[]
}

model Account {
  id        String   @id @default(uuid())
  name      String
  balance   Decimal  @default(0.0)
  type      String // checking, savings, wallet
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactionsFrom Transaction[] @relation("fromAccount")
  transactionsTo   Transaction[] @relation("toAccount")
}

model CreditCard {
  id         String   @id @default(uuid())
  name       String
  limit      Decimal
  closingDay Int
  dueDay     Int
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  color     String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id          String          @id @default(uuid())
  title       String
  description String?
  amount      Decimal
  type        TransactionType
  date        DateTime
  createdAt   DateTime        @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  accountFromId String?
  accountFrom   Account? @relation("fromAccount", fields: [accountFromId], references: [id])

  accountToId String?
  accountTo   Account? @relation("toAccount", fields: [accountToId], references: [id])

  creditCardId String?
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])

  installments Installment[]

  recurringId String?
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id])
}

model Installment {
  id      String   @id @default(uuid())
  number  Int
  total   Int
  amount  Decimal
  dueDate DateTime
  paid    Boolean  @default(false)

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Budget {
  id     String  @id @default(uuid())
  amount Decimal
  month  Int
  year   Int

  userId String
  user   User   @relation(fields: [userId], references: [id])

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
}

model RecurringTransaction {
  id        String              @id @default(uuid())
  title     String
  amount    Decimal
  type      TransactionType
  frequency RecurrenceFrequency
  startDate DateTime
  endDate   DateTime?
  active    Boolean             @default(true)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  transactions Transaction[]
}

model Experiment {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  startDate   DateTime
  endDate     DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  variants    ExperimentVariant[]
  assignments UserExperimentAssignment[]
  events      MetricEvent[]
}

model ExperimentVariant {
  id           String     @id @default(uuid())
  name         String
  slug         String
  experimentId String
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  assignments UserExperimentAssignment[]
  events      MetricEvent[]

  @@unique([experimentId, slug])
}

model UserExperimentAssignment {
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  experimentId String
  experiment   Experiment        @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  variantId    String
  variant      ExperimentVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  assignedAt   DateTime          @default(now())

  @@id([userId, experimentId])
}

model MetricEvent {
  id           String             @id @default(uuid())
  eventType    MetricEventType
  target       String?
  experimentId String?
  experiment   Experiment?        @relation(fields: [experimentId], references: [id], onDelete: SetNull)
  variantId    String?
  variant      ExperimentVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  metadata     Json?
  createdAt    DateTime           @default(now())

}

model Configuration {
  id          String   @id @default(uuid())
  name        String
  description String
  version     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
